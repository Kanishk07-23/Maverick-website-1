# ============================================================
#  Maverick Digitals — Environment Variables
#  Copy this file to .env.local and fill in the values.
#  NEVER commit .env.local to Git.
# ============================================================

# Gmail SMTP credentials (use a Gmail App Password, NOT your account password)
# How to generate: Google Account → Security → 2-Step Verification → App Passwords
SMTP_USER=maverickdigitals18@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# The inbox that receives contact form submissions (can be same as SMTP_USER)
CONTACT_RECIPIENT=maverickdigitals18@gmail.com

# Cloudflare Turnstile
# Get both keys at: https://dash.cloudflare.com → Turnstile → Add Site
# Site Key  → goes here as NEXT_PUBLIC (safe to expose to browser)
# Secret Key → goes here as TURNSTILE_SECRET_KEY (NEVER expose client-side)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAAxxxxxxxxxxxxxxxxx
TURNSTILE_SECRET_KEY=0x4AAAAAAAxxxxxxxxxxxxxxxxx
